# Serial port of the MeshCore Companion Radio
# Use /dev/serial/by-id/... for stable device names
MC_SERIAL_PORT=/dev/serial/by-id/usb-Espressif_USB_JTAG_serial_debug_unit_XXXX-if00

# Baud rate (default: 115200)
MC_BAUD_RATE=115200

# HTTP server
MC_HTTP_HOST=0.0.0.0
MC_HTTP_PORT=5003

# Number of channels to query from the radio (default: 8)
MC_NUM_CHANNELS=8

# Flask secret key - change this!
MC_SECRET_KEY=change-me-please
